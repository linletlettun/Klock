# Backend Environment Configuration

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Nacos Configuration
# Set to false to use real Nacos server
NACOS_MOCK=false
NACOS_SERVER_ADDR=http://localhost:8848
NACOS_NAMESPACE=public
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# K8s System Namespaces (comma-separated, optional)
# K8S_SYSTEM_NAMESPACES=kube-system,kube-public,kube-node-lease

# CORS Origins (comma-separated, optional)
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173
